generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model attendance {
  id              Int               @id @default(autoincrement())
  studentId       Int
  attendanceDate  DateTime          @db.Date
  checkInTime     DateTime?         @db.Time(0)
  checkOutTime    DateTime?         @db.Time(0)
  markedById      Int
  deviceId        String?
  method          attendance_method @default(MANUAL)
  status          attendance_status @default(PRESENT)
  user            user              @relation(fields: [markedById], references: [id], map: "Attendance_markedById_fkey")
  student         student           @relation(fields: [studentId], references: [id], map: "Attendance_studentId_fkey")
  attendanceaudit attendanceaudit[]

  @@index([markedById], map: "Attendance_markedById_fkey")
  @@index([studentId], map: "Attendance_studentId_fkey")
}

model attendanceaudit {
  id           Int        @id @default(autoincrement())
  attendanceId Int
  changedById  Int
  oldData      String     @db.Text
  newData      String     @db.Text
  reason       String?    @db.Text
  changedAt    DateTime   @default(now())
  attendance   attendance @relation(fields: [attendanceId], references: [id])
  user         user       @relation(fields: [changedById], references: [id])

  @@index([attendanceId], map: "AttendanceAudit_attendanceId_fkey")
  @@index([changedById], map: "AttendanceAudit_changedById_fkey")
}

model auditlog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String   @db.Text
  actionTime DateTime @default(now())
  user       user?    @relation(fields: [userId], references: [id], map: "AuditLog_userId_fkey")

  @@index([userId], map: "AuditLog_userId_fkey")
}

model billing {
  id              Int              @id @default(autoincrement())
  studentId       Int
  billingMonth    String
  amount          Decimal          @db.Decimal(10, 2)
  status          String           @default("UNPAID")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  categoryId      Int?
  invoiceUrl      String?
  student         student          @relation(fields: [studentId], references: [id], map: "Billing_studentId_fkey")
  billingCategory billingcategory? @relation(fields: [categoryId], references: [id])
  billingpayment  billingpayment[]

  @@index([studentId], map: "Billing_studentId_fkey")
  @@index([categoryId], map: "Billing_categoryId_fkey")
}

model billingpayment {
  id        Int     @id @default(autoincrement())
  billingId Int
  paymentId Int
  billing   billing @relation(fields: [billingId], references: [id], map: "BillingPayment_billingId_fkey")
  payment   payment @relation(fields: [paymentId], references: [id], map: "BillingPayment_paymentId_fkey")

  @@unique([billingId, paymentId], map: "BillingPayment_billingId_paymentId_key")
  @@index([paymentId], map: "BillingPayment_paymentId_fkey")
}

model classroom {
  id              Int               @id @default(autoincrement())
  name            String
  ageGroup        String?
  capacity        Int?
  status          classroom_status  @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  mealPlan        String?           @db.Text
  homework        homework[]
  notification    notification[]
  student         student[]
  billingcategory billingcategory[] @relation("billingcategorytoclassroom")
  event           event[]           @relation("classroomtoevent")
  teacherprofile  teacherprofile[]  @relation("classroomtoteacherprofile")
}

model teacherprofile {
  teacherId        Int                     @id
  qualification    String?
  qualificationPdf String?
  designation      teacher_designation     @default(ASSISTANT)
  qualifications   teacher_qualification[]
  user             user                    @relation(fields: [teacherId], references: [id], map: "TeacherProfile_teacherId_fkey")
  classroom        classroom[]             @relation("classroomtoteacherprofile")
}

model teacher_qualification {
  id             Int            @id @default(autoincrement())
  teacherId      Int
  title          String
  fileName       String?
  fileUrl        String?
  createdAt      DateTime       @default(now())
  teacherProfile teacherprofile @relation(fields: [teacherId], references: [teacherId])

  @@index([teacherId], map: "TeacherQualification_teacherId_fkey")
}

model event {
  id                 Int                  @id @default(autoincrement())
  title              String
  description        String?              @db.Text
  eventDate          DateTime             @db.Date
  startTime          String?
  endTime            String?
  location           String?
  status             event_status         @default(UPCOMING)
  createdById        Int
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  mediaUrl           String?
  user               user                 @relation(fields: [createdById], references: [id])
  event_attendance   event_attendance[]
  event_media        event_media[]
  event_waiting_list event_waiting_list[]
  classroom          classroom[]          @relation("classroomtoevent")

  @@index([createdById], map: "Event_createdById_fkey")
}

model expense {
  id          Int      @id @default(autoincrement())
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  expenseDate DateTime
  description String?  @db.Text
  createdAt   DateTime @default(now())
  receiptUrl  String?
}

model homework {
  id          Int       @id @default(autoincrement())
  classroomId Int
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  createdById Int
  createdAt   DateTime  @default(now())
  classroom   classroom @relation(fields: [classroomId], references: [id], map: "Homework_classroomId_fkey")
  user        user      @relation(fields: [createdById], references: [id], map: "Homework_createdById_fkey")

  @@index([classroomId], map: "Homework_classroomId_fkey")
  @@index([createdById], map: "Homework_createdById_fkey")
}

model notification {
  id                                     Int        @id @default(autoincrement())
  title                                  String
  message                                String     @db.Text
  targetRole                             String?
  targetClassroomId                      Int?
  createdById                            Int
  createdAt                              DateTime   @default(now())
  billingMonth                           String?
  targetParentId                         Int?
  user_notification_createdByIdTouser    user       @relation("notification_createdByIdTouser", fields: [createdById], references: [id], map: "Notification_createdById_fkey")
  classroom                              classroom? @relation(fields: [targetClassroomId], references: [id], map: "Notification_targetClassroomId_fkey")
  user_notification_targetParentIdTouser user?      @relation("notification_targetParentIdTouser", fields: [targetParentId], references: [id], map: "Notification_targetParentId_fkey")

  @@index([createdById], map: "Notification_createdById_fkey")
  @@index([targetClassroomId], map: "Notification_targetClassroomId_fkey")
  @@index([targetParentId], map: "Notification_targetParentId_fkey")
}

model parent {
  id                                     Int                 @id @default(autoincrement())
  parentUniqueId                         String              @unique(map: "Parent_parentUniqueId_key")
  fullName                               String
  relationship                           parent_relationship
  nationalId                             String?
  occupation                             String?
  address                                String?             @db.Text
  phone                                  String?             @unique(map: "Parent_phone_key")
  email                                  String?             @unique(map: "Parent_email_key")
  photoUrl                               String?
  status                                 parent_status       @default(ACTIVE)
  createdAt                              DateTime            @default(now())
  updatedAt                              DateTime            @updatedAt
  userId                                 Int?                @unique
  avatarType                             avatar_type         @default(ADULT)
  verificationCode                       String?             @unique
  meeting_requests                       meeting_request[]
  user                                   user?               @relation(fields: [userId], references: [id])
  student_student_parentIdToparent       student[]           @relation("student_parentIdToparent")
  student_student_secondParentIdToparent student[]           @relation("student_secondParentIdToparent")
}

model payment {
  id             Int              @id @default(autoincrement())
  paymentMethod  String
  receiptUrl     String?
  verifiedById   Int?
  verifiedAt     DateTime?
  createdAt      DateTime         @default(now())
  amountPaid     Decimal          @db.Decimal(10, 2)
  status         payment_status   @default(PENDING)
  transactionRef String?
  invoiceUrl     String?
  receiptNo      String?          @unique
  billingpayment billingpayment[]
  user           user?            @relation(fields: [verifiedById], references: [id], map: "Payment_verifiedById_fkey")

  @@index([verifiedById], map: "Payment_verifiedById_fkey")
}

model student {
  id                                    Int                  @id @default(autoincrement())
  studentUniqueId                       String               @unique(map: "Student_studentUniqueId_key")
  fullName                              String
  enrollmentDate                        DateTime?
  dateOfBirth                           DateTime?
  gender                                student_gender?
  medicalInfo                           String?              @db.Text
  emergencyContact                      String?
  photoUrl                              String?
  birthCertPdf                          String?
  parentId                              Int
  secondParentId                        Int?
  classroomId                           Int
  qrCode                                String?              @db.LongText
  status                                student_status       @default(ACTIVE)
  createdAt                             DateTime             @default(now())
  updatedAt                             DateTime             @updatedAt
  avatarType                            avatar_type          @default(CHILD)
  vaccineCardPdf                        String?
  assessments                           assessment[]
  attendance                            attendance[]
  billing                               billing[]
  event_attendance                      event_attendance[]
  event_waiting_list                    event_waiting_list[]
  meeting_requests                      meeting_request[]
  classroom                             classroom            @relation(fields: [classroomId], references: [id], map: "Student_classroomId_fkey")
  parent_student_parentIdToparent       parent               @relation("student_parentIdToparent", fields: [parentId], references: [id], map: "Student_parentId_fkey")
  parent_student_secondParentIdToparent parent?              @relation("student_secondParentIdToparent", fields: [secondParentId], references: [id], map: "Student_secondParentId_fkey")
  studentprogress                       studentprogress[]

  @@index([classroomId], map: "Student_classroomId_fkey")
  @@index([parentId], map: "Student_parentId_fkey")
  @@index([secondParentId], map: "Student_secondParentId_fkey")
}

model studentprogress {
  id          Int      @id @default(autoincrement())
  studentId   Int
  reading     Int?
  writing     Int?
  speaking    Int?
  listening   Int?
  mathematics Int?
  social      Int?
  remarks     String?  @db.Text
  updatedById Int
  updatedAt   DateTime @updatedAt
  student     student  @relation(fields: [studentId], references: [id], map: "StudentProgress_studentId_fkey")
  user        user     @relation(fields: [updatedById], references: [id], map: "StudentProgress_updatedById_fkey")

  @@index([studentId], map: "StudentProgress_studentId_fkey")
  @@index([updatedById], map: "StudentProgress_updatedById_fkey")
}

model user {
  id                                             Int               @id @default(autoincrement())
  employeeId                                     String?           @unique(map: "User_employeeId_key")
  role                                           user_role         @default(TEACHER)
  fullName                                       String
  email                                          String?
  phone                                          String?
  username                                       String            @unique(map: "User_username_key")
  password                                       String
  firstLogin                                     Boolean           @default(true)
  status                                         user_status       @default(ACTIVE)
  nationalId                                     String?
  address                                        String?           @db.Text
  joiningDate                                    DateTime?
  photoUrl                                       String?
  signatureUrl                                   String?
  createdAt                                      DateTime          @default(now())
  updatedAt                                      DateTime          @updatedAt
  resetToken                                     String?
  resetTokenExpires                              DateTime?
  isActive                                       Boolean           @default(true)
  isEmailVerified                                Boolean           @default(false)
  pushToken                                      String?
  assessments                                    assessment[]
  attendance                                     attendance[]
  attendanceaudit                                attendanceaudit[]
  auditlog                                       auditlog[]
  events                                         event[]
  homework                                       homework[]
  meetings_created                               meeting_request[] @relation("meeting_created_by")
  notification_notification_createdByIdTouser    notification[]    @relation("notification_createdByIdTouser")
  notification_notification_targetParentIdTouser notification[]    @relation("notification_targetParentIdTouser")
  otp                                            otp[]
  parent                                         parent?
  payment                                        payment[]
  report_logs                                    report_log[]
  studentprogress                                studentprogress[]
  teacherprofile                                 teacherprofile?
  temppasswordlog                                temppasswordlog[]
}

model meeting_request {
  id            Int            @id @default(autoincrement())
  parentId      Int
  teacherId     Int?
  studentId     Int?
  title         String
  description   String?        @db.Text
  requestDate   DateTime
  preferredTime String?
  status        meeting_status @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  parent        parent         @relation(fields: [parentId], references: [id])
  student       student?       @relation(fields: [studentId], references: [id])
  teacher       user?          @relation("meeting_created_by", fields: [teacherId], references: [id])

  @@index([parentId], map: "meeting_request_parentId_fkey")
  @@index([teacherId], map: "meeting_request_teacherId_fkey")
  @@index([studentId], map: "meeting_request_studentId_fkey")
}

model report_log {
  id            Int      @id @default(autoincrement())
  reportType    String
  dateRange     String
  generatedById Int
  filePath      String?
  createdAt     DateTime @default(now())
  user          user     @relation(fields: [generatedById], references: [id])

  @@index([generatedById], map: "ReportLog_generatedById_fkey")
}

model event_media {
  id        Int      @id @default(autoincrement())
  eventId   Int
  url       String
  type      String?  @default("IMAGE")
  createdAt DateTime @default(now())
  event     event    @relation(fields: [eventId], references: [id])

  @@index([eventId], map: "EventMedia_eventId_fkey")
}

model event_attendance {
  id        Int               @id @default(autoincrement())
  eventId   Int
  studentId Int
  status    attendance_status @default(PRESENT)
  event     event             @relation(fields: [eventId], references: [id])
  student   student           @relation(fields: [studentId], references: [id])

  @@unique([eventId, studentId], map: "EventAttendance_eventId_studentId_key")
  @@index([studentId], map: "EventAttendance_studentId_fkey")
}

model event_waiting_list {
  id          Int      @id @default(autoincrement())
  eventId     Int
  studentId   Int
  status      String   @default("PENDING")
  requestedAt DateTime @default(now())
  event       event    @relation(fields: [eventId], references: [id])
  student     student  @relation(fields: [studentId], references: [id])

  @@unique([eventId, studentId], map: "EventWaitingList_eventId_studentId_key")
  @@index([studentId], map: "EventWaitingList_studentId_fkey")
}

model otp {
  id        Int         @id @default(autoincrement())
  userId    Int
  codeHash  String
  expiresAt DateTime
  purpose   otp_purpose
  isUsed    Boolean     @default(false)
  createdAt DateTime    @default(now())
  user      user        @relation(fields: [userId], references: [id])

  @@index([userId], map: "OTP_userId_fkey")
}

model temppasswordlog {
  id           Int      @id @default(autoincrement())
  userId       Int
  passwordHash String
  expiresAt    DateTime
  used         Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         user     @relation(fields: [userId], references: [id], map: "tempPasswordLog_userId_fkey")

  @@index([userId], map: "TempPasswordLog_userId_fkey")
}

model special_day {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique @db.Date
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model skill_category {
  id     Int         @id @default(autoincrement())
  name   String      @unique
  skills sub_skill[]
}

model sub_skill {
  id         Int                @id @default(autoincrement())
  categoryId Int
  name       String
  scores     assessment_score[]
  category   skill_category     @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "SubSkill_categoryId_fkey")
}

model assessment {
  id          Int                @id @default(autoincrement())
  studentId   Int
  term        Int
  remarks     String?            @db.Text
  updatedById Int
  updatedAt   DateTime           @updatedAt
  student     student            @relation(fields: [studentId], references: [id])
  user        user               @relation(fields: [updatedById], references: [id])
  scores      assessment_score[]

  @@index([studentId], map: "Assessment_studentId_fkey")
  @@index([updatedById], map: "Assessment_updatedById_fkey")
}

model assessment_score {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  subSkillId   Int
  score        Int
  assessment   assessment @relation(fields: [assessmentId], references: [id])
  subSkill     sub_skill  @relation(fields: [subSkillId], references: [id])

  @@index([assessmentId], map: "AssessmentScore_assessmentId_fkey")
  @@index([subSkillId], map: "AssessmentScore_subSkillId_fkey")
}

model billingcategory {
  id         Int                       @id @default(autoincrement())
  name       String
  reason     String?                   @db.Text
  amount     Decimal                   @db.Decimal(10, 2)
  validUntil DateTime
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime
  frequency  billingcategory_frequency @default(RECURRING)
  billings   billing[]
  classroom  classroom[]               @relation("billingcategorytoclassroom")
}

enum user_role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STAFF
  CASHIER
}

enum parent_relationship {
  FATHER
  MOTHER
  GUARDIAN
}

enum classroom_status {
  ACTIVE
  INACTIVE
}

enum student_gender {
  MALE
  FEMALE
}

enum payment_status {
  PENDING
  APPROVED
  REJECTED
}

enum user_status {
  ACTIVE
  INACTIVE
}

enum parent_status {
  ACTIVE
  INACTIVE
}

enum student_status {
  ACTIVE
  INACTIVE
}

enum teacher_designation {
  LEAD
  ASSISTANT
}

enum attendance_status {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  COMPLETED
}

enum attendance_method {
  QR
  MANUAL
  SYSTEM
}

enum meeting_status {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum event_status {
  DRAFT
  PENDING
  APPROVED
  PUBLISHED
  UPCOMING
  COMPLETED
  CANCELLED
}

enum otp_purpose {
  FORGOT_PASSWORD
  EMAIL_VERIFY
  ACCOUNT_ACTIVATION
}

enum avatar_type {
  ADULT
  CHILD
}

enum billingcategory_frequency {
  ONE_TIME
  RECURRING
}
