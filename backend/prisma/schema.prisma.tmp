model billingCategory {
  id         Int                       @id @default(autoincrement())
  name       String
  reason     String?                   @db.Text
  amount     Decimal                   @db.Decimal(10, 2)
  validUntil DateTime
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime
  frequency  billingCategory_frequency @default(RECURRING)
  billings   billing[]
  classrooms classroom[]               @relation("billingcategorytoclassroom")

  @@map("billingcategory")
}
