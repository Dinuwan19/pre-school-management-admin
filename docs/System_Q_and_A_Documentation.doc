<head><title>System Architecture Q&A Documentation</title>
<style>
  body { font-family: 'Calibri', sans-serif; line-height: 1.6; color: #333; font-size: 11pt; }
  h1 { color: #2c3e50; border-bottom: 2px solid #7B57E4; padding-bottom: 5px; font-size: 24pt; }
  h2 { color: #7B57E4; margin-top: 30px; font-size: 18pt; background-color: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 5px solid #7B57E4; }
  h3 { color: #34495e; font-size: 14pt; font-weight: bold; margin-top: 20px; }
  p { margin-bottom: 15px; text-align: justify; }
  pre { background: #fdfdfd; padding: 15px; border-radius: 8px; font-family: 'Consolas', monospace; font-size: 9.5pt; border: 1px solid #e1e4e8; white-space: pre-wrap; word-wrap: break-word; color: #24292e; line-height: 1.4; }
  code { background: #f6f8fa; padding: 2px 4px; border-radius: 3px; font-family: 'Consolas', monospace; color: #d73a49; }
  ul { margin-bottom: 15px; }
  li { margin-bottom: 8px; }
  .lib { display: inline-block; background: #e8f0fe; color: #1967d2; padding: 2px 6px; border-radius: 4px; font-weight: bold; font-size: 9pt; }
</style>
