  .code-box { background-color: #282c34; color: #abb2bf; padding: 15px; border-radius: 8px; font-family: monospace; font-size: 12pt; white-space: pre-wrap; margin: 15px 0; }
  .highlight { color: #e06c75; font-weight: bold; }
